// Tells Prisma to generate a TypeScript client we import as "@prisma/client".
generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["postgresqlExtensions"]
}

// Where the database lives. Neon gives two URLs:
//   url       = pooled connection (host has "-pooler") → used by the running app
//   directUrl = direct connection (no "-pooler")        → used for migrations
datasource  db  {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DATABASE_URL_UNPOOLED")
    extensions = [vector]
}

// One uploaded PDF. Owned by the User who uploaded it.
model Document {
    id        String  @id @default(cuid())
    filename  String
    pageCount Int
    createdAt DateTime @default(now())
    chunks    chunk[]           // a Document has many Chunks
    userId    String            // who owns this document
    user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    messages  Message[]  

    @@index([userId])           // fast "all documents for this user" lookups
}

// One slice of a Document's text.
model chunk {
    id          String  @id @default(cuid())
    content    String                // the chunk text itself
    index      Int                   // order within the document (0, 1, 2, …)
    documentId String                // which Document this belongs to
    document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
    createdAt  DateTime @default(now()) 
    embedding  Unsupported("vector(768)")?   // 768 numbers from Gemini text-embedding-004

    @@index([documentId])           // makes "get all chunks for a document" fast
}

// --- Auth.js (NextAuth) tables. Names/fields are FIXED by the Prisma adapter. ---

// A person who signs in.
model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    documents     Document[]   // notes this user has uploaded
    messages      Message[]
}

// A link between a User and an OAuth provider (e.g. Google). One user can have several.
model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?
    user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

// An active login. We use database sessions, so each login lives here.
model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Used for email-link sign-in flows (unused with Google, but the adapter expects it).
model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// One chat message (a question or an answer), tied to a document and its owner.
model Message {
    id         String   @id @default(cuid())
    role       String   // "user" | "assistant"
    content    String
    documentId String
    document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
    userId     String
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt  DateTime @default(now())

    @@index([documentId])
}
